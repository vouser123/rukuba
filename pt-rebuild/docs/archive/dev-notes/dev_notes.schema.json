{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "title": "PT Rebuild Dev Notes",
  "type": "object",
  "required": [
    "metadata",
    "enums",
    "open_items",
    "closed_items"
  ],
  "properties": {
    "metadata": {
      "type": "object",
      "required": [
        "schema_version",
        "last_updated",
        "schema_file",
        "ux_approval_policy"
      ],
      "properties": {
        "schema_version": {
          "type": "string"
        },
        "last_updated": {
          "type": "string"
        },
        "schema_file": {
          "type": "string"
        },
        "ux_approval_policy": {
          "type": "string"
        }
      }
    },
    "enums": {
      "type": "object",
      "required": [
        "priority_levels",
        "risk_levels",
        "status_values",
        "issue_type_values",
        "ux_approval_status_values",
        "tag_vocabulary"
      ],
      "properties": {
        "priority_levels": { "type": "array" },
        "risk_levels": { "type": "array" },
        "status_values": { "type": "array" },
        "issue_type_values": { "type": "array" },
        "ux_approval_status_values": { "type": "array" },
        "tag_vocabulary": { "type": "array" }
      }
    },
    "open_items": {
      "type": "array"
    },
    "closed_items": {
      "type": "array"
    }
  },
  "x_enum_catalog": {
    "tag_vocabulary": [
      "ui",
      "ios",
      "pwa",
      "offline",
      "supabase",
      "auth",
      "sync",
      "data-model",
      "api",
      "performance",
      "reliability",
      "security",
      "migration",
      "docs",
      "bug",
      "cleanup",
      "email",
      "lcp",
      "notifications",
      "messages"
    ]
  }
}
