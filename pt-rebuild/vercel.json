{
  "redirects": [
    { "source": "/(.*)", "destination": "https://pttracker.app/$1", "permanent": false }
  ],
  "rewrites": [
    { "source": "/pt", "destination": "/pt_view.html" },
    { "source": "/track", "destination": "/index.html" }
  ],
  "crons": [
    { "path": "/api/logs?type=notify", "schedule": "0 13 * * *" }
  ]
}
